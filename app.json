{
  "expo": {
    "name": "iron.",
    "slug": "iron",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "iron",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#F5F0E1"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.iron.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5F0E1"
      },
      "package": "com.iron.app"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
